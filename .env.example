# Copy this to .env and fill in your values
# Never commit .env to GitHub

OPENAI_API_KEY=sk-...

# ChromaDB — local persistent storage path
CHROMA_PERSIST_DIR=./chroma_db

# Knowledge base directory
KB_DIR=./knowledge_base

# Visitor log file path
VISITOR_LOG_PATH=./logs/visitors.csv

# Calendly link — shown after certain question triggers
CALENDLY_URL=https://calendly.com/your-link-here

# App config
APP_TITLE=Chat with Anshul
